{
  "name": "react-ext",
  "version": "1.0.0",
  "scripts": {
    "dev": "npm install && concurrently \"webflow extension serve\" \"npm run watch-webpack\"",
    "build": "npm run build-webpack && webflow extension bundle",
    "watch-webpack": "webpack --config webpack.config.mjs --mode development --watch",
    "build-webpack": "webpack --config webpack.config.mjs --mode production"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.23.2",
    "@babel/preset-react": "^7.22.15",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@webflow/designer-extension-typings": "*",
    "babel-loader": "^9.1.3",
    "concurrently": "*",
    "crypto-browserify": "^3.12.0",
    "css-loader": "^7.1.4",
    "dotenv-webpack": "^8.1.0",
    "os-browserify": "^0.3.0",
    "path-browserify": "^1.0.1",
    "style-loader": "^4.0.0",
    "ts-loader": "^9.5.4",
    "typescript": "^6.0.2",
    "webpack": "^5.89.0",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "@emotion/react": "^11.11.4",
    "@emotion/styled": "^11.11.5",
    "@mui/icons-material": "^7.3.9",
    "@mui/material": "^7.3.9",
    "axios": "^1.7.8",
    "dotenv": "^16.4.5",
    "react-dom": "^18.2.0"
  },
  "babel": {
    "presets": [
      "@babel/preset-env",
      "@babel/preset-react"
    ]
  }
}
